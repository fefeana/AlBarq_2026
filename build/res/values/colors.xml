xml
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="?android:colorBackground"
    android:padding="16dp"
    android:layoutwidth="matchparent"
    android:layoutheight="matchparent">

    <!-- بطاقة زجاجية -->
    <LinearLayout
        android:orientation="vertical"
        android:background="@color/glassBackgroundDark"
        android:padding="16dp"
        android:layoutwidth="matchparent"
        android:layoutheight="wrapcontent"
        android:marginBottom="16dp">

        <TextView
            android:text="⚡ AlBarq Glass Card"
            android:textColor="?android:textColorPrimary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:layoutwidth="wrapcontent"
            android:layoutheight="wrapcontent"/>

        <TextView
            android:text="واجهة زجاجية دقيقة وشفافة"
            android:textColor="?android:textColorSecondary"
            android:textSize="14sp"
            android:layoutwidth="wrapcontent"
            android:layoutheight="wrapcontent"/>
    </LinearLayout>

    <!-- زر نيون -->
    <Button
        android:text="ابدأ الرحلة ⚡"
        style="@style/Widget.AlBarq.Button"
        android:layoutwidth="matchparent"
        android:layoutheight="wrapcontent"
        android:marginBottom="16dp"/>

    <!-- Progress Bar زجاجي -->
    <ProgressBar
        style="@style/Widget.AlBarq.ProgressBar"
        android:progress="65"
        android:max="100"
        android:layoutwidth="matchparent"
        android:layout_height="8dp"/>
</LinearLayout>
`
