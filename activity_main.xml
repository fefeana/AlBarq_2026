<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:gravity="center"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#101820">

    <!-- رسالة الخطأ -->
    <TextView
        android:id="@+id/aiErrorMsg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚡ رسالة النظام ستظهر هنا"
        android:textColor="#FFCC00"
        android:visibility="gone"
        android:padding="8dp"
        android:textSize="16sp"
        android:layout_marginBottom="20dp"/>

    <!-- زر Mirage -->
    <Button
        android:id="@+id/mirageBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🚀 اتصال Mirage"
        android:backgroundTint="#6200EE"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <!-- زر Cloud -->
    <Button
        android:id="@+id/cloudBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="☁️ اتصال Cloud"
        android:backgroundTint="#03DAC5"
        android:textColor="#000000"
        android:layout_marginBottom="12dp"/>

    <!-- زر إعادة الاتصال -->
    <Button
        android:id="@+id/reconnectBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔄 إعادة الاتصال"
        android:backgroundTint="#FF9800"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <!-- زر فصل الاتصال -->
    <Button
        android:id="@+id/disconnectBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⏹️ فصل الاتصال"
        android:backgroundTint="#B00020"
        android:textColor="#FFFFFF"/>
</LinearLayout>
